# API Configuration
# Set to 'mock' for development without backend, 'live' for real API
VITE_API_MODE=mock

# Backend API base URL
VITE_API_BASE_URL=http://localhost:8000

# Mapbox access token for map rendering and terrain elevation
# Get a free token at https://account.mapbox.com/access-tokens/
# Leave empty to use OSM tiles (elevation features will be disabled)
VITE_MAPBOX_TOKEN=
